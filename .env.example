# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Project Settings -> API -> service_role.
# SERVER ONLY. This key bypasses every RLS policy in the database.
# It must never appear in a NEXT_PUBLIC_* var, a client component, or the repo.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# From `stripe listen` locally, or the Dashboard webhook endpoint in prod.
# These differ per environment — using the prod secret locally fails silently.
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_TAX_ENABLED=false

# ---------------------------------------------------------------------------
# Print providers (all optional — an adapter registers only if its token is set)
# ---------------------------------------------------------------------------
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=
PRINTIFY_WEBHOOK_SECRET=

# Not yet implemented — see src/lib/providers/README.md
PRINTFUL_API_TOKEN=
GELATO_API_KEY=
CUSTOMCAT_API_KEY=

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
